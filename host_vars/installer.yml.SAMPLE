# installer.yml — SAMPLE host_vars for the installer/controller host
# Copy to host_vars/installer.yml and fill in real values.
# ---

# Use the current shell user on the controller
ansible_user: "{{ installer_user }}"
# aap_remote_user is the admin account on the remote AAP VM, not the local operator
aap_remote_user: "{{ admin_user | default('admin') }}"
ansible_ssh_private_key_file: "{{ rhis_installer_ssh_private_key_file | default('/home/' ~ installer_user ~ '/.ssh/rhis-installer/id_rsa') }}"
